<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="cabin_card_template">
        <!-- Cabin/Room Type Card - Horizontal Layout with Dark Blue Theme -->
        <div class="cabin-card-horizontal" style="border-radius: 24px; overflow: hidden; display: flex; background: linear-gradient(135deg, #0f2540 0%, #0a1c33 100%); box-shadow: 0 8px 32px rgba(0,0,0,0.3); min-height: 380px; margin-bottom: 30px;">

            <!-- LEFT SIDE: IMAGE CAROUSEL -->
            <div class="cabin-carousel-section" style="flex: 0 0 50%; position: relative; overflow: hidden;">
                <div class="cabin-carousel-container" style="width: 100%; height: 100%;">
                    <div class="carousel-wrapper" style="width: 100%; height: 100%;">
                        <!-- Carousel Track - Room Type Media -->
                        <div class="carousel-track" t-att-data-cabin-id="room_type.id" style="display: flex; width: 100%; height: 100%; transition: transform 0.5s ease;">
                            <!-- Primary room type media -->
                            <t t-if="room_type.media_ids and len(room_type.media_ids) > 0">
                                <t t-foreach="room_type.media_ids" t-as="media">
                                    <div class="carousel-slide" style="flex: 0 0 100%; width: 100%; height: 100%; position: relative;">
                                        <t t-if="media.image">
                                            <img class="carousel-image" t-att-src="image_data_uri(media.image)" t-att-alt="media.name or 'Cabin Image'" style="width: 100%; height: 100%; object-fit: cover;"/>
                                        </t>
                                        <t t-else="">
                                            <div class="carousel-placeholder" style="width: 100%; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; background: linear-gradient(135deg, #1a3a52 0%, #0d2236 100%);">
                                                <span style="font-size: 48px;">🛏️</span>
                                                <p style="color: #fff; margin-top: 10px;">No Image</p>
                                            </div>
                                        </t>
                                    </div>
                                </t>
                            </t>
                            <!-- Fallback to property images if room type has no media -->
                            <t t-else="">
                                <t t-if="cruise and cruise.property_id and cruise.property_id.media_ids and len(cruise.property_id.media_ids) > 0">
                                    <t t-foreach="cruise.property_id.media_ids" t-as="media">
                                        <div class="carousel-slide" style="flex: 0 0 100%; width: 100%; height: 100%; position: relative;">
                                            <t t-if="media.image">
                                                <img class="carousel-image" t-att-src="image_data_uri(media.image)" t-att-alt="media.name or 'Property Image'" style="width: 100%; height: 100%; object-fit: cover;"/>
                                            </t>
                                            <t t-else="">
                                                <div class="carousel-placeholder" style="width: 100%; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; background: linear-gradient(135deg, #1a3a52 0%, #0d2236 100%);">
                                                    <span style="font-size: 48px;">🏨</span>
                                                    <p style="color: #fff; margin-top: 10px;">No Image</p>
                                                </div>
                                            </t>
                                        </div>
                                    </t>
                                </t>
                                <t t-else="">
                                    <div class="carousel-slide" style="flex: 0 0 100%; width: 100%; height: 100%; position: relative;">
                                        <div class="carousel-placeholder" style="width: 100%; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; background: linear-gradient(135deg, #1a3a52 0%, #0d2236 100%);">
                                            <span style="font-size: 48px;">🛏️</span>
                                            <p style="color: #fff; margin-top: 10px;">No Images</p>
                                        </div>
                                    </div>
                                </t>
                            </t>
                        </div>

                        <!-- Navigation Arrows -->
                        <t t-set="media_count" t-value="len(room_type.media_ids) if room_type.media_ids else (len(cruise.property_id.media_ids) if (cruise and cruise.property_id and cruise.property_id.media_ids) else 0)"/>
                        <t t-if="media_count > 1">
                            <button class="carousel-nav carousel-prev" t-att-onclick="'prevSlide(this)'" title="Previous" style="position: absolute; left: 15px; top: 50%; transform: translateY(-50%); z-index: 10; width: 40px; height: 40px; border-radius: 50%; background: rgba(255,255,255,0.9); border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; box-shadow: 0 2px 8px rgba(0,0,0,0.2); transition: all 0.3s;">
                                <i class="fa fa-chevron-left" style="color: #0f2540; font-size: 18px;"></i>
                            </button>
                            <button class="carousel-nav carousel-next" t-att-onclick="'nextSlide(this)'" title="Next" style="position: absolute; right: 15px; top: 50%; transform: translateY(-50%); z-index: 10; width: 40px; height: 40px; border-radius: 50%; background: rgba(255,255,255,0.9); border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; box-shadow: 0 2px 8px rgba(0,0,0,0.2); transition: all 0.3s;">
                                <i class="fa fa-chevron-right" style="color: #0f2540; font-size: 18px;"></i>
                            </button>

                            <!-- Carousel Indicators -->
                            <div class="carousel-indicators" style="position: absolute; bottom: 15px; left: 50%; transform: translateX(-50%); display: flex; gap: 8px; z-index: 10;">
                                <t t-if="room_type.media_ids and len(room_type.media_ids) > 0">
                                    <t t-foreach="room_type.media_ids" t-as="media">
                                        <button class="indicator" t-att-data-index="media_index" t-att-class="'indicator' + (' active' if media_index == 0 else '')" t-att-onclick="'goToSlide(this, %d)' % media_index" style="width: 10px; height: 10px; border-radius: 50%; background: rgba(255,255,255,0.4); border: 2px solid rgba(255,255,255,0.6); cursor: pointer; transition: all 0.3s;"></button>
                                    </t>
                                </t>
                                <t t-else="">
                                    <t t-if="cruise and cruise.property_id and cruise.property_id.media_ids">
                                        <t t-foreach="cruise.property_id.media_ids" t-as="media">
                                            <button class="indicator" t-att-data-index="media_index" t-att-class="'indicator' + (' active' if media_index == 0 else '')" t-att-onclick="'goToSlide(this, %d)' % media_index" style="width: 10px; height: 10px; border-radius: 50%; background: rgba(255,255,255,0.4); border: 2px solid rgba(255,255,255,0.6); cursor: pointer; transition: all 0.3s;"></button>
                                        </t>
                                    </t>
                                </t>
                            </div>
                        </t>
                    </div>
                </div>
            </div>

            <!-- RIGHT SIDE: CONTENT -->
            <div class="cabin-card-body" style="flex: 0 0 50%; padding: 30px; display: flex; flex-direction: column; justify-content: space-between; color: white;">

                <!-- TOP SECTION: TITLE AND DETAILS -->
                <div>
                    <!-- CABIN TITLE AND AREA -->
                    <div class="cabin-header">
                        <div class="cabin-title-wrap">
                            <h3 class="cabin-name" style="margin: 0 0 8px 0; font-size: 26px; font-weight: 600; background: linear-gradient(135deg, #c9a84c, #e8c97a); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; letter-spacing: 0.5px;">
                                <t t-esc="room_type.name"/>
                            </h3>
                            <t t-if="room_type.area">
                                <div class="cabin-area" style="display: flex; align-items: center; color: #c9a84c; font-size: 13px; gap: 6px;">
                                    <i class="fa fa-expand"></i>
                                    <span><t t-esc="room_type.area"/></span>
                                </div>
                            </t>
                        </div>
                    </div>

                    <!-- DESCRIPTION -->
                    <t t-if="room_type.description">
                        <div class="cabin-description" style="margin-top: 12px; color: #d4d4d4; font-size: 13px; line-height: 1.6; max-height: 60px; overflow-y: auto;">
                            <t t-out="room_type.description"/>
                        </div>
                    </t>

                    <!-- FACILITIES/FEATURES SECTION - ACCORDION -->
                    <t t-if="room_type.facilities">
                        <div class="cabin-features" style="margin-top: 10px;">
                            <div class="accordion accordion-flush" t-att-id="'acc-' + str(room_type.id)" style="background: transparent; border: none;">
                                <div class="accordion-item" style="background: transparent; border: 1px solid rgba(201,168,76,0.3); border-radius: 6px; margin: 0;">
                                    <h2 class="accordion-header" style="margin: 0;">
                                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" t-att-data-bs-target="'#col-' + str(room_type.id)" aria-expanded="false" t-att-aria-controls="'col-' + str(room_type.id)" style="background: transparent; color: #c9a84c; font-size: 11px; font-weight: 700; text-transform: uppercase; padding: 6px 10px; letter-spacing: 1px;">
                                            ✨ Amenities
                                        </button>
                                    </h2>
                                    <div t-att-id="'col-' + str(room_type.id)" class="accordion-collapse collapse" t-att-data-bs-parent="'#acc-' + str(room_type.id)" style="background: transparent;">
                                        <div class="accordion-body" style="background: rgba(201,168,76,0.08); padding: 8px 10px; border-top: 1px solid rgba(201,168,76,0.2);">
                                            <div class="features-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 6px;">
                                                <t t-foreach="room_type.facilities" t-as="facility">
                                                    <div class="feature-item" style="display: flex; align-items: center; font-size: 11px; color: #b8b8b8; gap: 5px;">
                                                        <t t-if="facility.icon">
                                                            <t t-if="facility.icon.startswith('fa-')">
                                                                <i class="fa" t-att-class="'fa ' + facility.icon" style="color: #c9a84c; font-size: 12px; flex-shrink: 0;"></i>
                                                            </t>
                                                            <t t-else="">
                                                                <span class="feature-icon" style="font-size: 12px; flex-shrink: 0;"><t t-esc="facility.icon"/></span>
                                                            </t>
                                                        </t>
                                                        <span class="feature-name" style="flex: 1;"><t t-esc="facility.name"/></span>
                                                    </div>
                                                </t>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </div>

                <!-- BOTTOM SECTION: PRICE, ROOMS AND ACTION -->
                <div>
                    <!-- DIVIDER -->
                    <div class="cabin-divider" style="border-top: 1px solid rgba(201,168,76,0.2); margin: 20px 0;"></div>

                    <!-- FOOTER WITH PRICE AND SELECTION -->
                    <div class="cabin-footer" style="display: flex; gap: 15px; align-items: flex-end; justify-content: space-between;">

                        <!-- PRICE SECTION -->
                        <div class="cabin-price-section">
                            <div class="price-label" style="font-size: 11px; color: #999; margin-bottom: 4px; text-transform: uppercase;">Price</div>
                            <t t-value="cruise.sudo().get_room_rate_in_egp(persons_count, room_type)" t-set="double_room_price"/>
                            <div class="price-amount" style="display: flex; align-items: baseline; gap: 2px;">
                                <sup style="font-size: 12px; color: #c9a84c;">EGP</sup>
                                <span style="font-size: 22px; font-weight: 700; background: linear-gradient(135deg, #c9a84c, #e8c97a); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
                                    <t t-esc="'{:,.0f}'.format(double_room_price)"/>
                                </span>
                            </div>
                        </div>

                        <!-- ROOM SELECTION SECTION -->
                        <div class="room-selection" style="display: flex; align-items: center; gap: 8px;">
                            <label class="selection-label" style="font-size: 11px; color: #999; text-transform: uppercase; white-space: nowrap;">Qty:</label>
                            <div class="room-selector" style="display: flex; align-items: center; gap: 6px;">
                                <button class="room-btn minus-btn" onclick="decrementRooms(this)" title="Decrease" style="width: 30px; height: 30px; border: 1px solid #c9a84c; background: transparent; color: #c9a84c; border-radius: 4px; cursor: pointer; font-weight: 600; transition: all 0.3s;">
                                    <i class="fa fa-minus"></i>
                                </button>
                                <t t-set="max_rooms" t-value="min(5, cruise.sudo().get_room_max_availability(room_type))"/>
                                <input type="number" class="room-input" min="1" t-att-max="max_rooms" value="1" readonly="1" style="width: 45px; text-align: center; border: 1px solid #c9a84c; background: rgba(201,168,76,0.1); border-radius: 4px; padding: 6px; color: #c9a84c; font-weight: 600;"/>
                                <button class="room-btn plus-btn" onclick="incrementRooms(this)" title="Increase" style="width: 30px; height: 30px; border: 1px solid #c9a84c; background: transparent; color: #c9a84c; border-radius: 4px; cursor: pointer; font-weight: 600; transition: all 0.3s;">
                                    <i class="fa fa-plus"></i>
                                </button>
                            </div>
                        </div>

                        <!-- ADD TO BOOKING BUTTON -->
                        <button class="btn-add-room" onclick="addRoomToBooking(this)" t-att-data-room-type-id="room_type.id" t-att-data-max-rooms="max_rooms" style="padding: 10px 18px; background: linear-gradient(135deg, #c9a84c 0%, #e8c97a 100%); color: #0f2540; border: none; border-radius: 6px; font-weight: 700; cursor: pointer; white-space: nowrap; font-size: 13px; transition: all 0.3s; box-shadow: 0 4px 12px rgba(201, 168, 76, 0.3);">
                            <i class="fa fa-plus" style="margin-right: 5px;"></i>Add
                        </button>
                    </div>
                </div>

            </div>

        </div>
    </template>

    <!-- CABIN CARDS CONTAINER TEMPLATE -->
    <template id="cabin_cards_list">
          <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css"
                  integrity="sha384-1BmE4kWBq78iYhFldvKuhfTAU6auU8tT94WrHftjDbrCEXSU1oBoqyl2QvZ6jIW3"
                  crossorigin="anonymous"/>
<!--        <link rel="stylesheet" href="/cleopatra_cruise/static/src/css/new_style.css"/>-->
        <link rel="stylesheet" href="/cleopatra_cruise/static/src/css/cabin_card.css"/>
         <div class="particles" id="particles"/>
        <t t-call="cleopatra_cruise.search_bar" />
        <div class="cabin-cards-container py-5">
            <div class="container">
                <div class="cabin-cards-header">
                    <h2 class="section-title">Choose Your Cabin</h2>
                    <p class="section-subtitle">Select from our luxurious cabin types and customize your experience</p>
                </div>

                <div class="row g-4" style="margin-top: 20px;">
                    <t t-foreach="room_types" t-as="room_type">
                        <div class="col-12">
                            <t t-call="cleopatra_cruise.cabin_card_template"/>
                        </div>
                    </t>
                </div>
            </div>
        </div>
          <script src="/cleopatra_cruise/static/src/js/script.js" type="text/javascript"></script>
    </template>

</odoo>

