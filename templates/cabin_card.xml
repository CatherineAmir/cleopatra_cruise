<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="cabin_card_template">
        <!-- Cabin/Room Type Card with Image Carousel -->
        <div class="cabin-card" style="border-radius:24px; overflow:hidden; position:relative;">

            <!-- IMAGE CAROUSEL SECTION -->
            <div class="cabin-carousel-container">
                <div class="carousel-wrapper">
                    <!-- Carousel Track -->
                    <div class="carousel-track" t-att-data-cabin-id="room_type.id">
                        <!-- Primary room type media -->
                        <t t-if="room_type.media_ids and len(room_type.media_ids) > 0">
                            <t t-foreach="room_type.media_ids" t-as="media">
                                <div class="carousel-slide">
                                    <t t-if="media.image">
                                        <img class="carousel-image" t-att-src="image_data_uri(media.image)" alt="Cabin Image"/>
                                    </t>
                                    <t t-else="">
                                        <div class="carousel-placeholder">
                                            <span style="font-size: 48px;">📷</span>
                                            <p>No Image</p>
                                        </div>
                                    </t>
                                </div>
                            </t>
                        </t>
                        <!-- Fallback to property images if room type has no media -->
                        <t t-else="">
                            <t t-if="cruise and cruise.property_id and cruise.property_id.media_ids and len(cruise.property_id.media_ids) > 0">
                                <t t-foreach="cruise.property_id.media_ids" t-as="media">
                                    <div class="carousel-slide">
                                        <t t-if="media.image">
                                            <img class="carousel-image" t-att-src="image_data_uri(media.image)" alt="Property Image"/>
                                        </t>
                                        <t t-else="">
                                            <div class="carousel-placeholder">
                                                <span style="font-size: 48px;">🏨</span>
                                                <p>No Image</p>
                                            </div>
                                        </t>
                                    </div>
                                </t>
                            </t>
                            <t t-else="">
                                <div class="carousel-slide">
                                    <div class="carousel-placeholder">
                                        <span style="font-size: 48px;">🛏️</span>
                                        <p>No Images Available</p>
                                    </div>
                                </div>
                            </t>
                        </t>
                    </div>

                    <!-- Navigation Arrows -->
                    <t t-set="media_count" t-value="len(room_type.media_ids) if room_type.media_ids else (len(cruise.property_id.media_ids) if (cruise and cruise.property_id and cruise.property_id.media_ids) else 0)"/>
                    <t t-if="media_count > 1">
                        <button class="carousel-nav carousel-prev" t-att-onclick="'prevSlide(this)'" title="Previous">
                            <i class="fa fa-chevron-left"></i>
                        </button>
                        <button class="carousel-nav carousel-next" t-att-onclick="'nextSlide(this)'" title="Next">
                            <i class="fa fa-chevron-right"></i>
                        </button>

                        <!-- Carousel Indicators -->
                        <div class="carousel-indicators">
                            <t t-if="room_type.media_ids and len(room_type.media_ids) > 0">
                                <t t-foreach="room_type.media_ids" t-as="media">
                                    <button class="indicator" t-att-data-index="media_index" t-att-class="'indicator' + (' active' if media_index == 0 else '')" t-att-onclick="'goToSlide(this, %d)' % media_index"></button>
                                </t>
                            </t>
                            <t t-else="">
                                <t t-if="cruise and cruise.property_id and cruise.property_id.media_ids">
                                    <t t-foreach="cruise.property_id.media_ids" t-as="media">
                                        <button class="indicator" t-att-data-index="media_index" t-att-class="'indicator' + (' active' if media_index == 0 else '')" t-att-onclick="'goToSlide(this, %d)' % media_index"></button>
                                    </t>
                                </t>
                            </t>
                        </div>
                    </t>
                </div>

                <!-- Wave Divider -->
                <svg class="wave-svg-cabin" height="18" viewBox="0 0 420 18" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M0,0 C70,18 140,0 210,10 C280,20 350,4 420,10 L420,0 Z" fill="#0f2540"/>
                </svg>
            </div>

            <!-- CARD BODY SECTION -->
            <div class="cabin-card-body">

                <!-- CABIN TITLE AND AREA -->
                <div class="cabin-header">
                    <div class="cabin-title-wrap">
                        <h3 class="cabin-name">
                            <t t-esc="room_type.name"/>
                        </h3>
                        <t t-if="room_type.area">
                            <div class="cabin-area">
                                <i class="fa fa-expand" style="margin-right: 4px;"></i>
                                <t t-esc="room_type.area"/>
                            </div>
                        </t>
                    </div>
                </div>

                <!-- DESCRIPTION -->
                <t t-if="room_type.description">
                    <div class="cabin-description">
                        <t t-out="room_type.description"/>
                    </div>
                </t>

                <!-- FACILITIES/FEATURES SECTION -->
                <t t-if="room_type.facilities">
                    <div class="cabin-features">
                        <div class="features-title">✨ Features &amp; Amenities</div>
                        <div class="features-grid">
                            <t t-foreach="room_type.facilities" t-as="facility">
                                <div class="feature-item">
                                    <t t-if="facility.icon">
                                        <t t-if="facility.icon.startswith('fa-')">
                                            <i class="fa" t-att-class="'fa ' + facility.icon" style="margin-right: 6px;"></i>
                                        </t>
                                        <t t-else="">
                                            <span class="feature-icon"><t t-esc="facility.icon"/></span>
                                        </t>
                                    </t>
                                    <span class="feature-name"><t t-esc="facility.name"/></span>
                                </div>
                            </t>
                        </div>
                    </div>
                </t>

                <!-- DIVIDER -->
                <div class="cabin-divider"></div>

                <!-- PRICE AND SELECTION SECTION -->
                <div class="cabin-footer">
                    <!-- PRICE SECTION -->
                    <div class="cabin-price-section">
                        <div class="price-info">
                            <div class="price-label">Double  Room Price</div>
                            <t t-value="cruise.sudo().get_room_rate_in_egp(persons_count, room_type)" t-set="double_room_price"/>
                            <div class="price-amount">
                                <sup>EGP</sup>
                                <span id="priceDisplay" t-att-data-base-price="double_room_price">
                                  <t t-esc="'{:,.0f}'.format(double_room_price)"
                                                  />
                                </span>

                            </div>
                        </div>
                    </div>

                    <!-- ROOM SELECTION SECTION -->
                    <div class="room-selection">
                        <label class="selection-label">Number of Rooms</label>
                        <div class="room-selector">
                            <button class="room-btn minus-btn" onclick="decrementRooms(this)" title="Decrease">
                                <i class="fa fa-minus"></i>
                            </button>
                            <t t-set="max_rooms" t-value="min(5, cruise.sudo().get_room_max_availability(room_type))"/>
                            <input type="number" class="room-input" min="1" t-att-max="max_rooms" value="1" readonly="1"/>
<!--                            <input type="number" class="room-input" min="1" t-att-max="5" value="1" readonly="1"/>-->
                            <button class="room-btn plus-btn" onclick="incrementRooms(this)" title="Increase">
                                <i class="fa fa-plus"></i>
                            </button>
                        </div>
                    </div>

                    <!-- ADD TO BOOKING BUTTON -->
                    <button class="btn-add-room" onclick="addRoomToBooking(this)">
                        <i class="fa fa-plus" style="margin-right: 6px;"></i>Add to Booking
                    </button>
                </div>

            </div>

        </div>
    </template>

    <!-- CABIN CARDS CONTAINER TEMPLATE -->
    <template id="cabin_cards_list">
          <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css"
                  integrity="sha384-1BmE4kWBq78iYhFldvKuhfTAU6auU8tT94WrHftjDbrCEXSU1oBoqyl2QvZ6jIW3"
                  crossorigin="anonymous"/>
        <link rel="stylesheet" href="/cleopatra_cruise/static/src/css/new_style.css"/>
         <div class="particles" id="particles"/>
        <t t-call="cleopatra_cruise.search_bar" />
        <div class="cabin-cards-container py-5">
            <div class="container">
                <div class="cabin-cards-header">
                    <h2 class="section-title">Choose Your Cabin</h2>
                    <p class="section-subtitle">Select from our luxurious cabin types and customize your experience</p>
                </div>

                <div class="row g-4" style="margin-top: 20px;">
                    <t t-foreach="room_types" t-as="room_type">
                        <div class="col-12 col-md-6">
                            <t t-call="cleopatra_cruise.cabin_card_template"/>
                        </div>
                    </t>
                </div>
            </div>
        </div>
          <script src="/cleopatra_cruise/static/src/js/script.js" type="text/javascript"></script>
    </template>

</odoo>

