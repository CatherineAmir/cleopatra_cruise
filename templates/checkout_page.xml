<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="checkout_page" name="Checkout Page">
        <t t-call="website.layout">
            <t t-set="additional_title">Checkout</t>
            <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css"
                  integrity="sha384-1BmE4kWBq78iYhFldvKuhfTAU6auU8tT94WrHftjDbrCEXSU1oBoqyl2QvZ6jIW3"
                  crossorigin="anonymous"/>
            <link rel="stylesheet" href="/cleopatra_cruise/static/src/css/checkout.css"/>

            <div class="checkout-page-wrapper">
                <div class="container py-5">
                    <!-- Back Button -->
                    <div style="margin-bottom: 20px;">
                        <a href="javascript:void(0)" class="checkout-back-btn" onclick="goBackToCabin()">
                            <i class="fa fa-arrow-left" style="font-size: 16px;"></i>
                            <span>Back to Cabin Selection</span>
                        </a>
                    </div>

                    <div class="row g-4">
                        <!-- Left: Guest Form -->
                        <div class="col-lg-7">
                            <div class="checkout-card">
                                <h3 class="checkout-card-title">Main Guest Details</h3>
                                <form id="checkoutForm" action="/paynow" method="post">
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label class="form-label checkout-form-label">First Name <span class="text-danger">*</span></label>
                                            <input type="text" class="form-control checkout-input" id="guestFirstName" required="required" placeholder="Enter first name"/>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label checkout-form-label">Last Name <span class="text-danger">*</span></label>
                                            <input type="text" class="form-control checkout-input" id="guestLastName" required="required" placeholder="Enter last name"/>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label checkout-form-label">Email <span class="text-danger">*</span></label>
                                            <input type="email" class="form-control checkout-input" id="guestEmail" required="required" placeholder="email@example.com"/>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label checkout-form-label">Mobile <span class="text-danger">*</span></label>
                                            <input type="tel" class="form-control checkout-input" id="guestMobile" required="required" placeholder="+20 xxx xxx xxxx"/>
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label checkout-form-label">Country <span class="text-danger">*</span></label>
                                            <select class="form-select checkout-input" id="guestCountry" required="required">
                                                <option value="">Select Country</option>
                                                <t t-foreach="countries or []" t-as="country">
                                                    <option t-att-value="country.id" t-esc="country.name"/>
                                                </t>
                                            </select>
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label checkout-form-label">Notes <span class="text-muted">(Optional)</span></label>
                                            <textarea class="form-control checkout-input" id="guestNotes" rows="3" placeholder="Any special requests or notes..."></textarea>
                                        </div>
                                        <div class="col-12">
                                            <div class="form-check terms-check">
                                                <input class="form-check-input" type="checkbox" id="acceptTerms" required="required"/>
                                                <label class="form-check-label" for="acceptTerms">
                                                    I accept the
                                                    <a href="javascript:void(0)" class="terms-link" onclick="openTermsOverlay()">Terms &amp; Conditions</a>
                                                </label>
                                            </div>
                                        </div>
                                        <div class="col-12 mt-4">
                                            <button type="submit" class="btn btn-pay-now w-100" id="btnPayNow" disabled="disabled">
                                                <span class="pay-icon">🔒</span> Pay Now
                                            </button>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>

                        <!-- Right: Summary -->
                        <div class="col-lg-5">
                            <div class="checkout-card summary-card">
                                <h3 class="checkout-card-title">Reservation Summary</h3>
                                <div id="checkoutSummaryItems" class="summary-items-list">
                                    <p class="text-muted text-center">Loading...</p>
                                </div>
                                <div class="summary-divider"></div>
                                <div class="summary-total-row">
                                    <span>Total</span>
                                    <span id="checkoutTotalPrice" class="summary-total-price">EGP 0</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Terms Overlay -->
            <div class="terms-overlay" id="termsOverlay">
                <div class="terms-modal">
                    <div class="terms-header">
                        <h4>Terms &amp; Conditions</h4>
                        <button type="button" class="btn-close-terms" onclick="closeTermsOverlay()">✕</button>
                    </div>
                    <div class="terms-body">
                       <t t-out="cruise.batch_id.terms_and_conditions"/>
                    </div>
                    <div class="terms-footer">
                        <button type="button" class="btn btn-accept-terms" onclick="acceptTermsFromOverlay()">I Accept</button>
                    </div>
                </div>
            </div>

            <script src="/cleopatra_cruise/static/src/js/checkout.js" type="text/javascript"></script>
        </t>
    </template>
</odoo>

