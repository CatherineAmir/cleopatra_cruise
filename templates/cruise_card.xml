<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="cruise_card_template">

<!--            <div class="d-flex flex-column align-items-center justify-content-center"-->
<!--     style="min-height: 100vh; padding: 30px 16px;">-->
                <div class="container-fluid  py-5">
            <div class="row g-4" style="margin-top: 40px;">
                <t t-foreach="cruises" t-as="cruise">
                    <t t-set="index" t-value="1"/>

                    <div class="col-12 col-md-4">

                        <div class="cruise-card " id="cruiseCard" style="border-radius:24px; overflow:hidden; position:relative;">


                            <!-- HERO -->
                            <!--                 src="https://images.unsplash.com/photo-1548574505-5e239809ee19?w=900&amp;auto=format&amp;fit=crop"-->
                            <div class="card-hero">
                                <img
                                        class="hero-img"
                                        src="/cleopatra_cruise/static/src/img/cleopatra/Cleopatra-Luxury-Cruise-and-Spa-gallery-02.jpg"
                                        alt="Luxury Cruise Ship"
                                />
                                <div class="hero-gradient"></div>

                                <span class="badge-featured">Featured Voyage</span>

                                <div class="hero-rating">
                                    <span class="star-icon">★</span>
                                    4.9
                                </div>
<!---->
                                <div class="hero-title-wrap">
                                    <div class="hero-name">Nile Cruise &amp;nbsp;·&amp;nbsp; From
                                        <t t-esc="cruise.city.capitalize()"/>
                                        <t t-esc="cruise.number_of_nights"/>
                                        ·&amp;nbsp; Nights
                                    </div>
                                    <!--                        <div class="hero-name">The <em>Aegean</em> Grand<br/>Odyssey-->
                                    <!--                        </div>-->
                                </div>
                            </div>

                            <!-- wave -->
                            <svg class="wave-svg" height="18" viewBox="0 0 420 18" preserveAspectRatio="none"
                                 xmlns="http://www.w3.org/2000/svg">
                                <path d="M0,0 C70,18 140,0 210,10 C280,20 350,4 420,10 L420,0 Z" fill="#0f2540"/>
                            </svg>

                             BODY
                            <div class="card-body-section">
<!---->
                                <!-- highlights -->
                                <div class="highlights">
                                    <div class="highlight-item">
                                        <div class="hi-value">
                                            <t t-esc="cruise.number_of_nights"/>
                                        </div>
                                        <div class="hi-label">Nights</div>
                                    </div>
                                    <div class="highlight-item">
                                        <div class="hi-value">7</div>
                                        <div class="hi-label">Ports</div>
                                    </div>
                                    <div class="highlight-item">
                                        <div class="hi-value">850</div>
                                        <div class="hi-label">Guests</div>
                                    </div>
                                    <div class="highlight-item">
                                        <div class="hi-value">5★</div>
                                        <div class="hi-label">Class</div>
                                    </div>
                                </div>
<!---->
                                <!-- DATE PICKER -->
                                <div class="date-section">
                                    <div class="date-section-label">Check Your Voyage Dates</div>
                                    <div class="date-row">
                                        <!-- Embarkation -->
                                        <div class="date-box" id="boxIn">
                                            <span class="db-icon">⚓</span>
                                            <div class="db-type">Embark</div>
                                            <div class="db-day" id="dispIn">
                                                <t t-esc="cruise.start_date.strftime('%d %b %Y')"/>
                                            </div>
                                            <div class="db-weekday" id="dispInDay">
                                                <t t-esc="cruise.start_day"/>
                                            </div>
                                            <!--                                <input type="date" t-attf-id="dateIn_${index}" t-att-value="cruise.start_date"/>-->
                                        </div>

                                        <div class="date-arrow">→</div>

                                        <!-- Disembarkation -->
                                        <div class="date-box" id="boxOut">
                                            <span class="db-icon">🏝</span>
                                            <div class="db-type">Disembark</div>
                                            <div class="db-day" id="dispOut">
                                                <t t-esc="cruise.end_date.strftime('%d %b %Y')"/>
                                            </div>
                                            <div class="db-weekday" id="dispOutDay">
                                                <t t-esc="cruise.end_day"/>
                                            </div>
                                            <!--                                <input type="date" id="dateOut" t-att-value="cruise.end_date"/>-->
                                        </div>
                                    </div>

                                    <!-- duration pill -->
                                    <div class="duration-pill" id="durationPill" style="display:none">
                                        ⛵
                                        <span id="durationText"></span>
                                    </div>
                                </div>

                                <!-- port stops -->
                                <div class="port-stops">
                                    <div class="port">
                                        <div class="port-dot start"></div>
                                        <span class="port-name" style="left:50%">Athens</span>
                                    </div>
                                    <div class="port-line"></div>
                                    <div class="port">
                                        <div class="port-dot"></div>
                                        <span class="port-name" style="left:50%">Santorini</span>
                                    </div>
                                    <div class="port-line"></div>
                                    <div class="port">
                                        <div class="port-dot"></div>
                                        <span class="port-name" style="left:50%">Mykonos</span>
                                    </div>
                                    <div class="port-line"></div>
                                    <div class="port">
                                        <div class="port-dot"></div>
                                        <span class="port-name" style="left:50%">Rhodes</span>
                                    </div>
                                    <div class="port-line"></div>
                                    <div class="port">
                                        <div class="port-dot"></div>
                                        <span class="port-name" style="left:50%">Valletta</span>
                                    </div>
                                    <div class="port-line"></div>
                                    <div class="port">
                                        <div class="port-dot end"></div>
                                        <span class="port-name" style="left:50%">Rome</span>
                                    </div>
                                </div>

                                <p style="margin-bottom:6px; margin-top:26px;"></p>

                                <!-- description -->
                                <p class="card-desc">
                                    <t t-esc="cruise.property_id.description"/>
                                </p>

                                <!-- amenities -->
                                <div class="amenities">
                                    <t t-if="cruise.property_id and cruise.property_id.facilities">
                                        <t t-foreach="cruise.property_id.facilities" t-as="facility">
                                            <span class="amenity-tag">
                                                <t t-if="facility.icon and facility.icon.startswith('fa-')">
                                                    <i class="fa" t-att-class="'fa ' + facility.icon" style="margin-right: 6px;"></i>
                                                </t>
                                                <t t-else="">
                                                    <span class="icon"><t t-esc="facility.icon or '✨'"/></span>
                                                </t>
                                                <t t-esc="facility.name"/>
                                            </span>
                                        </t>
                                    </t>
                                    <t t-else="">
                                        <span class="amenity-tag">
                                            <i class="fa fa-utensils" style="margin-right: 6px;"></i>
                                            Fine Dining
                                        </span>
                                        <span class="amenity-tag">
                                            <i class="fa fa-swimming-pool" style="margin-right: 6px;"></i>
                                            Infinity Pool
                                        </span>
                                        <span class="amenity-tag">
                                            <i class="fa fa-masks" style="margin-right: 6px;"></i>
                                            Live Shows
                                        </span>
                                        <span class="amenity-tag">
                                            <i class="fa fa-spa" style="margin-right: 6px;"></i>
                                            Spa &amp; Wellness
                                        </span>
                                        <span class="amenity-tag">
                                            <i class="fa fa-anchor" style="margin-right: 6px;"></i>
                                            Shore Excursions
                                        </span>
                                    </t>
                                </div>
<!---->
                            </div>

                            <div class="gold-divider"></div>
<!---->
                            <!-- FOOTER -->
                            <div class="card-footer-section">
                                <div class="price-wrap">
                                    <div class="price-label">From For <t t-esc="persons_count"></t> person</div>
                                    <div class="price-amount"><sup>EGP</sup>
                                       <t t-esc="'{:,.0f}'.format(cruise.sudo().get_rate_in_egp_minimum(persons_count))"
                                                  />
                                    </div>
                                    <div class="price-note">All-inclusive</div>
                                </div>

                                <!-- Booking Details Display -->
<!--                                <div class="booking-details">-->
<!--                                    <div class="detail-row">-->
<!--                                        <span class="detail-label">📅 From:</span>-->
<!--                                        <span class="detail-value" id="bookDetailFrom">Select Date</span>-->
<!--                                    </div>-->
<!--                                    <div class="detail-row">-->
<!--                                        <span class="detail-label">📅 To:</span>-->
<!--                                        <span class="detail-value" id="bookDetailTo">Select Date</span>-->
<!--                                    </div>-->
<!--                                    <div class="detail-row">-->
<!--                                        <span class="detail-label">👥 Persons:</span>-->
<!--                                        <span class="detail-value" id="bookDetailPersons">2</span>-->
<!--                                    </div>-->
<!--                                </div>-->

                                <button class="btn-book" id="bookBtn" t-att-data-cruise-id="cruise.id" onclick="bookNowWithCurrentParams(this)">Book Now</button>
                            </div>
                        </div>
                    </div>
                    <t t-set="index" t-value="index + 1"/>

                            <script src="/cleopatra_cruise/static/src/js/script.js" type="text/javascript"></script>
                </t>
            </div>
            </div>


    </template>
</odoo>