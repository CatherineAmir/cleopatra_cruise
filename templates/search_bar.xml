<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="search_bar" name="Search Bar">
        <link rel="stylesheet" href="/cleopatra_cruise/static/src/css/search_bar.css"/>

        <!-- MAIN SEARCH BAR - CENTERED RECTANGLE -->
        <div class="search-bar-wrapper">
            <div class="search-bar-container">
                <div class="sb-title">Search Voyages</div>

                <form t-att-action="search_action or '/cruises'" method="post" id="searchForm" class="search-bar-form">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                    <div class="search-bar-fields">
                        <!-- FROM DATE -->
                        <div class="sb-field" id="sbFromField">
                            <span class="sf-icon">📅</span>
                            <div class="sf-label">From</div>
                            <div class="sf-value" id="sbFromVal">Select</div>
                            <div class="sf-sub" id="sbFromSub">Month · Year</div>
                            <input type="hidden" name="date_from" id="dateFromInput" value=""/>
                            <div class="month-dropdown" id="mdFrom">
                                <div class="md-year-row">
                                    <button class="md-yr-btn" type="button" onclick="event.preventDefault(); shiftYear('from',-1)">‹</button>
                                    <span class="md-yr-label" id="mdFromYear">2026</span>
                                    <button class="md-yr-btn" type="button" onclick="event.preventDefault(); shiftYear('from',1)">›</button>
                                </div>
                                <div class="md-months" id="mdFromMonths"></div>
                            </div>
                        </div>

                        <!-- TO DATE -->
                        <div class="sb-field" id="sbToField">
                            <span class="sf-icon">📅</span>
                            <div class="sf-label">To</div>
                            <div class="sf-value" id="sbToVal">Select</div>
                            <div class="sf-sub" id="sbToSub">Month · Year</div>
                            <input type="hidden" name="date_to" id="dateToInput" value=""/>
                            <div class="month-dropdown" id="mdTo">
                                <div class="md-year-row">
                                    <button class="md-yr-btn" type="button" onclick="event.preventDefault(); shiftYear('to',-1)">‹</button>
                                    <span class="md-yr-label" id="mdToYear">2026</span>
                                    <button class="md-yr-btn" type="button" onclick="event.preventDefault(); shiftYear('to',1)">›</button>
                                </div>
                                <div class="md-months" id="mdToMonths"></div>
                            </div>
                        </div>

                        <!-- ROOMS (Opens Overlay) -->
                        <div class="sb-field rooms-field" id="sbRoomsField" onclick="openRoomsOverlay(event)">
                            <span class="sf-icon">🛏️</span>
                            <div class="sf-label">Rooms</div>
                            <div class="sf-value" id="sbRoomsVal"><t t-esc="rooms_count" />Room(s)</div>
                            <div class="sf-sub" id="sbRoomsSub"><t t-esc="persons_count"/></div>
                            <input type="hidden" name="rooms_count" id="roomsCountInput" t-att-value="rooms_count"/>
                            <input type="hidden" name="rooms_data" id="roomsDataInput" t-att-value="rooms_data"/>
                            <input type="hidden" name="persons_count" id="personsCountInput" t-att-value="persons_count"/>

                        </div>

                        <!-- CURRENCY -->
                        <div class="sb-field currency-field">
                            <span class="sf-icon">💱</span>
                            <div class="sf-label">Currency</div>
                            <select name="currency" id="currencySelect" class="sf-currency-select">
                                <option value="EGP" t-att-selected="'selected' if (currency or 'EGP') == 'EGP' else None">EGP</option>
                                <option value="USD" t-att-selected="'selected' if (currency or 'EGP') == 'USD' else None">USD</option>
                            </select>
                        </div>

                        <!-- GO BUTTON -->
                        <button class="sb-search-btn" id="sbSearchBtn" type="submit">
                            <span class="sb-icon">🔍</span>
                            <span>GO</span>
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- ROOMS OVERLAY MODAL -->
        <div class="rooms-overlay" id="roomsOverlay" onclick="closeRoomsOverlay()">
            <div class="rooms-modal" onclick="event.stopPropagation()">
                <div class="modal-header">
                    <h2>🛏️ Rooms &amp; Guests</h2>
                    <button class="modal-close" type="button" onclick="closeRoomsOverlay()">✕</button>
                </div>

                <div class="modal-content">
                    <div class="rooms-list" id="rdRoomsList"></div>
                </div>

                <div class="modal-footer">
                    <button class="modal-add-btn" type="button" id="rdAddRoomBtn" onclick="addRoom()">+ Add Room</button>
                    <button class="modal-done-btn" type="button" onclick="closeRoomsOverlay()">Done</button>
                </div>
            </div>
        </div>

        <script type="text/javascript" src="/cleopatra_cruise/static/src/js/search_bar.js"/>

    </template>

</odoo>