<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="search_bar" name="Search Bar">
        <link rel="stylesheet" href="/cleopatra_cruise/static/src/css/style.css"/>
        <!--        <div class="search-bar">-->
        <div class="row search-bar  justify-content-center">
            <div class="sb-title">Search Voyages</div>

<!--        <div class="row content-center">-->

            <form action="/cruises" method="post" id="searchForm"
                  class="form-inline w-100 d-flex align-items-center justify-content-center">


                <input type="hidden" name="csrf_token"
                       t-att-value="request.csrf_token()"/>
                <!--                <div class="row">-->
                <!-- FROM month -->
                <div class="row align-items-center ">
                    <div class="col sb-field" id="sbFromField">
                        <!--                <div class="sb-field" id="sbFromField">-->
                        <span class="sf-icon">📅</span>
                        <div class="sf-label">From</div>
                        <div class="sf-value" id="sbFromVal">Select</div>
                        <div class="sf-sub" id="sbFromSub">Month · Year</div>
                        <!-- Hidden input for date_from -->
                        <input type="hidden" name="date_from" id="dateFromInput" value=""/>
                        <!-- dropdown -->
                        <div class="month-dropdown" id="mdFrom">
                            <div class="md-year-row">
                                <button class="md-yr-btn" type="button"
                                        onclick="event.preventDefault(); shiftYear('from',-1)">‹
                                </button>
                                <span class="md-yr-label" id="mdFromYear">2026</span>
                                <button class="md-yr-btn" type="button"
                                        onclick="event.preventDefault(); shiftYear('from',1)">›
                                </button>
                            </div>
                            <div class="md-months" id="mdFromMonths"></div>
                        </div>
                    </div>
                    <!--                            </div>-->
                    <div class="col sb-field" id="sbToField">
                        <!-- TO month -->
                        <!--                <div class="sb-field" id="sbToField">-->
                        <span class="sf-icon">📅</span>
                        <div class="sf-label">To</div>
                        <div class="sf-value" id="sbToVal">Select</div>
                        <div class="sf-sub" id="sbToSub">Month · Year</div>
                        <!-- Hidden input for date_to -->
                        <input type="hidden" name="date_to" id="dateToInput" value=""/>
                        <div class="month-dropdown" id="mdTo">
                            <div class="md-year-row">
                                <button class="md-yr-btn" type="button"
                                        onclick="event.preventDefault(); shiftYear('to',-1)">‹
                                </button>
                                <span class="md-yr-label" id="mdToYear">2026</span>
                                <button class="md-yr-btn" type="button"
                                        onclick="event.preventDefault(); shiftYear('to',1)">›
                                </button>
                            </div>
                            <div class="md-months" id="mdToMonths"></div>
                        </div>
                    </div>

                    <!-- PERSONS -->

                    <div class="col sb-field persons-field align-items-center">
                        <div class="text-center w-100 mb-1">
<!--                        <span class="sf-icon text-center">👥</span>-->
                        <div class="sf-label" style="font-size: 10px;" > 👥 Guests</div>
                            </div>
                        <div class="persons-ctrl d-flex align-items-center justify-content-center">
                            <button class="pctrl-btn" type="button" id="btnMinus" onclick="updatePersons(-1)">−</button>
                            <span class="pctrl-num" id="personsNum">
                                <t t-esc="person_count"/>
                            </span>
                            <button class="pctrl-btn" type="button" id="btnPlus" onclick="updatePersons(1)">+</button>
                        </div>
                        <!-- Hidden input for persons_count -->
                        <input type="hidden" name="persons_count" id="personsCountInput" t-att-value="person_count" t-att-data="person_count"/>
                        <div class="sf-label text-center mt-2" id="personsSub">Persons</div>
                    </div>
                </div>
                <div class="row justify-content-center mt-3">
                <!-- SEARCH BTN -->
                    <div class="col-auto">
                <button class="sb-search-btn d-block" id="sbSearchBtn" type="submit">
                    <span class="sb-icon">🔍</span>
                    <span>GO</span>
                </button>

                </div>

                                    </div>
            </form>

        </div>

    </template>

</odoo>