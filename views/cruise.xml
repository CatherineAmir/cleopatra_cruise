<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- list view -->
    <record id="view_cruise_cruise_list" model="ir.ui.view">
        <field name="name">cruise.cruise.list</field>
        <field name="model">cruise.cruise</field>
        <field name="arch" type="xml">
            <list string="Cruises">
                <field name="name"/>
                <field name="batch_id"/>
                <field name="start_date"/>
                <field name="start_day"/>
                <field name="number_of_nights"/>
                <field name="city"/>
                <field name="end_date_computed"/>
                <field name="end_day"/>
            </list>
        </field>
    </record>

    <!-- form view -->
    <record id="view_cruise_cruise_form" model="ir.ui.view">
        <field name="name">cruise.cruise.form</field>
        <field name="model">cruise.cruise</field>
        <field name="arch" type="xml">
            <form string="Cruise">
                <sheet>
                    <!--                    <div class="alert alert-info" role="alert" attrs="{'invisible': [('fully_booked', '=', False)]}">-->
                    <!--                        <strong>This cruise is fully booked!</strong>-->
                    <!--                    </div>-->

                    <label for="name" string="Name"/>
                    <h1>
                        <field name="name" readonly="1"/>
                    </h1>
                    <!--                    </group>-->
                    <group>
                        <group string="From">
                            <field name="start_date"/>
                            <field name="start_day" readonly="1"/>
                        </group>

                        <group string="To">

                            <field name="end_date_computed" readonly="1"/>
                            <field name="end_day" readonly="1"/>
                        </group>
                    </group>
                    <group>


                        <group string="Cruise Information">


                            <field name="batch_id" readonly="1"/>
                            <field name="city"/>
                            <field name="number_of_nights"/>
                        </group>
                        <group string="Booking Information">
                            <field name="reservation_count" readonly="1"/>
                            <field name="fully_booked" readonly="1"/>
                            <field name="available_for_booking" widget="boolean_toggle"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Room Availability">
                            <field name="room_availability_ids">
                                <list editable="bottom">
                                    <field name="room_id"/>
                                    <field name="total_rooms"/>
                                    <field name="reserved_rooms"/>
                                    <field name="available_rooms"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>


            </form>
        </field>
    </record>
    <!-- Cruises action -->
    <record id="action_cruise_cruise" model="ir.actions.act_window">
        <field name="name">Cruises</field>
        <field name="res_model">cruise.cruise</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_cruise_cruise_list"/>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Create a new cruise
            </p>
        </field>
    </record>
</odoo>
