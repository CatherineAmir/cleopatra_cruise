<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- list view -->
    <record id="view_cruise_batch_list" model="ir.ui.view">
        <field name="name">cruise.batch.list</field>
        <field name="model">cruise.batch</field>
        <field name="arch" type="xml">
            <list string="Batches">
                <field name="name"/>
                <field name="start_date"/>
                <field name="end_date"/>
            </list>
        </field>
    </record>

    <!-- form view -->
    <record id="view_cruise_batch_form" model="ir.ui.view">
        <field name="name">cruise.batch.form</field>
        <field name="model">cruise.batch</field>
        <field name="arch" type="xml">
            <form string="Cruise Batch">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="start_date"/>
                        <field name="end_date"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- search view -->
    <record id="view_cruise_batch_search" model="ir.ui.view">
        <field name="name">cruise.batch.search</field>
        <field name="model">cruise.batch</field>
        <field name="arch" type="xml">
            <search string="Batches">
                <field name="name"/>
                <field name="start_date"/>
                <field name="end_date"/>
            </search>
        </field>
    </record>

    <!-- action -->
    <record id="action_cruise_batch" model="ir.actions.act_window">
        <field name="name">Batches</field>
        <field name="res_model">cruise.batch</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_cruise_batch_list"/>
        <field name="search_view_id" ref="view_cruise_batch_search"/>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Create a new cruise batch
            </p>
        </field>
    </record>

    <!-- menu under Configuration -->

</odoo>