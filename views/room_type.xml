<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- list view -->
    <record id="view_cruise_room_type_list" model="ir.ui.view">
        <field name="name">cruise.room_type.list</field>
        <field name="model">cruise.room_type</field>
        <field name="arch" type="xml">
            <list string="Room Types">
                <field name="name"/>
                <field name="total_number"/>
                <field name="facilities" widget="many2many_tags"/>
            </list>
        </field>
    </record>

    <!-- form view -->
    <record id="view_cruise_room_type_form" model="ir.ui.view">
        <field name="name">cruise.room_type.form</field>
        <field name="model">cruise.room_type</field>
        <field name="arch" type="xml">
            <form string="Cruise Room Type">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_media" type="object" class="oe_stat_button" icon="fa-image">
                            <field string="Media" name="media_count" widget="statinfo"/>
                        </button>
                    </div>
                    <group>
                        <field name="name"/>
                        <field name="total_number"/>
                        <field name="facilities" widget="many2many_tags"/>
                        <field name="area"/>
                    </group>
                    <notebook>
                        <page string="Media">
                            <field name="media_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="select"/>
                                    <field name="image" widget="image" invisible="select != 'image'"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- action -->
    <record id="action_cruise_room_type" model="ir.actions.act_window">
        <field name="name">Room Types</field>
        <field name="res_model">cruise.room_type</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_cruise_room_type_list"/>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Create a new room type
            </p>
        </field>
    </record>

    <!-- menu under Configuration -->
    
</odoo>
