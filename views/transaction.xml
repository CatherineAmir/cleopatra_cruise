<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="transaction_form_inherit" model="ir.ui.view">
            <field name="name">reservation_transaction.form</field>
            <field name="model">transaction</field>
            <field name="inherit_id" ref="sita_payment_integration.sita_transaction_form"/>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='internal_note']" position="after">
                    <field name="client_id" invisible="1"/>
                    <field name="reservation_reference" readonly="1" />
                </xpath>

            </field>
        </record>
    </data>
</odoo>