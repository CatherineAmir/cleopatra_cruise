<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Cleopatra app main menu -->
    <menuitem id="menu_cleopatra_app"
              name="Cleopatra"
              sequence="10"/>

    <!-- Configuration submenu -->
    <menuitem id="menu_cleopatra_config"
              name="Configuration"
              parent="menu_cleopatra_app"
              sequence="20"/>

<!--    Batches Menu-->
    <menuitem id="menu_cleopatra_batches"
              name="Batches"
              parent="menu_cleopatra_config"
              sequence="10"
              action="action_cruise_batch"/>

    <menuitem id="menu_cleopatra_facilities"
              name="Facilities"
              parent="menu_cleopatra_config"
              sequence="20"
              action="action_cruise_facilities"/>

    <menuitem id="menu_cleopatra_room_types"
              name="Room Types"
              parent="menu_cleopatra_config"
              sequence="30"
              action="action_cruise_room_type"/>

    <menuitem id="menu_cleopatra_media"
              name="Media"
              parent="menu_cleopatra_config"
              sequence="40"
              action="action_media"/>

    <menuitem id="menu_cleopatra_property"
              name="Properties"
              parent="menu_cleopatra_config"
              sequence="50"
              action="action_property"/>

    <!-- Cruises menu -->
    <menuitem id="menu_cleopatra_cruises"
              name="Cruises"
              parent="menu_cleopatra_app"
              sequence="10"
              action="action_cruise_cruise"/>

    <!-- Reservations action -->
    <record id="action_cruise_reservation" model="ir.actions.act_window">
        <field name="name">Reservations</field>
        <field name="res_model">cruise.reservation</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_cruise_reservation_list"/>
        <field name="search_view_id" ref="view_cruise_reservation_search"/>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Create a new reservation
            </p>
        </field>
    </record>

    <!-- Reservations menu -->
    <menuitem id="menu_cleopatra_reservations"
              name="Reservations"
              parent="menu_cleopatra_app"
              sequence="1"
              action="action_cruise_reservation"/>
</odoo>