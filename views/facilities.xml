<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- list view -->
    <record id="view_cruise_facilities_list" model="ir.ui.view">
        <field name="name">cruise.facilities.list</field>
        <field name="model">cruise.facilities</field>
        <field name="arch" type="xml">
            <list string="Facilities" editable="bottom">
              
                 
                <field name="name"/>
            </list>
        </field>
    </record>


    <!-- form view -->
    <record id="view_cruise_facilities_form" model="ir.ui.view">
        <field name="name">cruise.facilities.form</field>
        <field name="model">cruise.facilities</field>
        <field name="arch" type="xml">
            <form string="Cruise Facilities">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- action -->
    <record id="action_cruise_facilities" model="ir.actions.act_window">
        <field name="name">Facilities</field>
        <field name="res_model">cruise.facilities</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_cruise_facilities_list"/>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Create a new facility
            </p>
        </field>
    </record>

    <!-- menu under Configuration -->
   
</odoo>
