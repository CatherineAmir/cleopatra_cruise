<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Reservation line list view -->
    <record id="view_cruise_reservation_line_list" model="ir.ui.view">
        <field name="name">cruise.reservation_line.list</field>
        <field name="model">cruise.reservation_line</field>
        <field name="arch" type="xml">
            <list string="Reservation Lines" editable="bottom">
                <field name="room_id"/>
                <field name="number_of_rooms"/>
                <field name="number_of_persons"/>
                <field name="total_amount"/>
            </list>
        </field>
    </record>

    <!-- Reservation list view -->
    <record id="view_cruise_reservation_list" model="ir.ui.view">
        <field name="name">cruise.reservation.list</field>
        <field name="model">cruise.reservation</field>
        <field name="arch" type="xml">
            <list string="Reservations">
                <field name="ref"/>
                <field name="cruise_id"/>
                <field name="batch_id"/>
                <field name="guest_id"/>
                <field name="guest_email"/>
                <field name="guest_phone"/>
                <field name="guest_country"/>
                <field name="reservation_state"/>
                <field name="payment_state"/>
                <field name="total_amount"/>

            </list>
        </field>
    </record>

    <!-- Reservation form view -->
    <record id="view_cruise_reservation_form" model="ir.ui.view">
        <field name="name">cruise.reservation.form</field>
        <field name="model">cruise.reservation</field>
        <field name="arch" type="xml">
            <form string="Reservation">
                <button name="create_transaction_link" string="Create Payment Link" type="object" class="oe_highlight"/>
           
                <sheet>
                 <field name="reservation_state" widget="statusbar" statusbar_visible="draft,confirmed,cancelled"/>
                   
                    <h1>
                        <field name="ref" readonly="1"/>
                    </h1>
                    <group>
                        <field name="cruise_id" readonly="1"/>
                        <field name="batch_id" readonly="1"/>
                        <field name="create_date"/>
                    </group>
                    <group string="Guest Information">
                        <field name="guest_id" readonly="1"/>
                        <field name="guest_email" readonly="1"/>
                        <field name="guest_phone" readonly="1"/>
                        <field name="guest_country" readonly="1"/>

                    </group>
                    <group>
                        <field name="reservation_state" invisible="1"/>
                        <field name="payment_state" invisible="1"/>
                        <field name="payment_transaction_state"/>
                        <field name="total_amount" readonly="1"/>
                        <field name="secondary_total_amount" readonly="1"/>
                        <field name="currency_id"/>
                        <field name="secondary_currency_id"/>
                        <field name="payment_transaction_id"/>

                    </group>
                    <notebook>
                        <page string="Reservation Lines" >
                            <field name="reservation_line_ids" readonly="1">
                                <list editable="bottom">
                                    <field name="room_id"/>
                                    <field name="number_of_rooms"/>
                                    <field name="number_of_persons"/>
                                    <field name="number_of_nights"/>
                                    <field name="total_amount" sum="Total"/>
                                    <field name="total_amount_secondary" sum="Total"/>
                                    <field name="currency_id" readonly="1" column_invisible="1"/>
                                    <field name="secondary_currency_id" readonly="1" column_invisible="1"/>
                                </list>
                            </field>
                        </page>


                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Reservation search view -->
    <record id="view_cruise_reservation_search" model="ir.ui.view">
        <field name="name">cruise.reservation.search</field>
        <field name="model">cruise.reservation</field>
        <field name="arch" type="xml">
            <search string="Reservations">
                <field name="cruise_id" />
                <field name="guest_id"/>
                <field name="guest_email"/>
                <field name="guest_phone"/>
                <field name="guest_country"/>
                <field name="reservation_state"/>
                <field name="payment_state"/>
            </search>
        </field>
    </record>
</odoo>
