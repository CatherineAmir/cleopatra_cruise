<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

           <record id="reservation_sequence" model="ir.sequence">
            <field name="name">reservation seq.</field>
            <field name="code">reservation_seq</field>
            <field name="prefix">Reservation/%(year)s/%(month)s/%(day)s/</field>
            <field name="padding">3</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="use_date_range">True</field>
        </record>

        <record id="media_sequence" model="ir.sequence">
            <field name="name">Media Seq.</field>
            <field name="code">media_seq</field>
            <field name="prefix">Media_</field>
            <field name="padding">3</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>

        </record>
    </data>
</odoo>